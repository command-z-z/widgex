[Unit]
Description=Widgex widget daemon
Documentation=https://github.com/command-z-z/widgex
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/widgex daemon start --foreground --config %h/.config/widgex/config.toml
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
